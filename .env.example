# App
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/executor

# Playwright project root folder
# Use an absolute path, for example:
PLAYWRIGHT_PROJECT_ROOT_FOLDER=/home/your-user/path/to/playwright-project
ALLOWED_PLAYWRIGHT_PROJECTS=cigna,aetna,shared
MAX_PLAYWRIGHT_WORKERS=8
MAX_PLAYWRIGHT_RETRIES=3

# Socket sync service
SOCKET_SYNC_SERVER_URL=http://localhost:3016

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
EXECUTION_QUEUE_NAME=playwright-executions
EXECUTION_JOB_ATTEMPTS=3
EXECUTION_JOB_BACKOFF_MS=5000
WORKER_CONCURRENCY=3
STOP_KILL_GRACE_MS=10000
SOCKET_CORS_ORIGIN=*
